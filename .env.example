# PostgreSQL (Neon, local Docker, etc.)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/drshoes

# CORS — comma-separated origins (Next.js dev + production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API
API_PREFIX=/api/v1
PAGE_SIZE=8
DEBUG=true

# Auth (change SECRET_KEY in production!)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Images — local disk (see README for S3/CDN)
STATIC_URL_BASE=http://localhost:8000/static
MAX_UPLOAD_SIZE_MB=5

# Shop
SHIPPING_COST=150000
FREE_SHIPPING_MIN=5000000

# Seed admin (created on first seed if no users exist)
ADMIN_EMAIL=admin@drshoes.local
ADMIN_PASSWORD=admin123456
ADMIN_FULL_NAME=مدیر فروشگاه
