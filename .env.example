# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/drshoes

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_PREFIX=/api/v1
PAGE_SIZE=8
DEBUG=true

SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Storage: local (default) — files in Backend/media/ ──
STORAGE_BACKEND=local
STATIC_URL_BASE=http://localhost:8000/static
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=50

# ── Later: switch to S3 (MinIO / AWS / Supabase S3 API) ──
# STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=http://127.0.0.1:9000
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_BUCKET_NAME=drshoes-media
# S3_REGION=us-east-1
# S3_PUBLIC_URL_BASE=http://127.0.0.1:9000/drshoes-media
# S3_AUTO_CREATE_BUCKET=true
# Then: python -m scripts.migrate_media_to_s3

SHIPPING_COST=150000
FREE_SHIPPING_MIN=5000000

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@drshoes.local
ADMIN_PHONE=09000000000
ADMIN_PASSWORD=admin123456
ADMIN_FULL_NAME=مدیر فروشگاه
